{
  "name": "theme",
  "version": "4.0.1",
  "description": "",
  "scripts": {
    "start": "npm run dev",
    "build": "npm run build:clean && npm run build:tailwind",
    "build:clean": "rimraf ../../static/css/tailwind.css",
    "build:tailwind": "cross-env NODE_ENV=production postcss ./styles.css -o ../../static/css/tailwind.css --minify",
    "dev": "cross-env NODE_ENV=development CHOKIDAR_USEPOLLING=1 CHOKIDAR_INTERVAL=1000 postcss ./styles.css -o ../../static/css/tailwind.css --watch"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "cross-env": "^7.0.3",
    "daisyui": "^5.5.19",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.1",
    "postcss-nested": "^7.0.2",
    "postcss-simple-vars": "^7.0.1",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.2.2"
  },
  "dependencies": {
    "tailwindcss-animated": "^2.0.0"
  }
}
